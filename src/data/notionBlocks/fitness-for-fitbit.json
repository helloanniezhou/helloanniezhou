    {
      "id": "340bef17-e035-8046-b4db-c75d2700c6da",
      "type": "paragraph",
      "richText": [
        {
          "type": "text",
          "text": "Pixel Watch 3 was Google's third-generation wearable. With growing competition in the health and fitness space, we needed to ",
          "bold": false,
          "italic": false,
          "strikethrough": false,
          "underline": false,
          "code": false,
          "color": "default",
          "href": null
        },
        {
          "type": "text",
          "text": "transition from a data tracking and dashboard product",
          "bold": true,
          "italic": false,
          "strikethrough": false,
          "underline": false,
          "code": false,
          "color": "default",
          "href": null
        },
        {
          "type": "text",
          "text": " to a ",
          "bold": false,
          "italic": false,
          "strikethrough": false,
          "underline": false,
          "code": false,
          "color": "default",
          "href": null
        },
        {
          "type": "text",
          "text": "coaching product",
          "bold": true,
          "italic": false,
          "strikethrough": false,
          "underline": false,
          "code": false,
          "color": "default",
          "href": null
        },
        {
          "type": "text",
          "text": " in order to differentiate through intelligence and guidance.",
          "bold": false,
          "italic": false,
          "strikethrough": false,
          "underline": false,
          "code": false,
          "color": "default",
          "href": null
        }
