      "type": "bulleted_list_item",
      "richText": [
        {
          "type": "text",
          "text": "Standard workout ",
          "bold": true,
          "italic": false,
          "strikethrough": false,
          "underline": false,
          "code": false,
          "color": "default",
          "href": null
        },
        {
          "type": "text",
          "text": "The entire workout is one session.",
