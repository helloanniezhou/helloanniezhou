    {
      "id": "341bef17-e035-80be-aeca-d63d2ec8a455",
      "type": "paragraph",
      "richText": [
        {
          "type": "text",
          "text": "When I joined, UXR often relied on static Figma mocks, which limited realism for wearables. I ",
          "bold": false,
          "italic": false,
          "strikethrough": false,
          "underline": false,
          "code": false,
          "color": "default",
          "href": null
        },
        {
          "type": "text",
          "text": "advocated for real-world wearable testing",
          "bold": true,
          "italic": false,
          "strikethrough": false,
          "underline": false,
          "code": false,
          "color": "default",
          "href": null
        },
        {
          "type": "text",
          "text": " and ",
          "bold": false,
          "italic": false,
          "strikethrough": false,
          "underline": false,
          "code": false,
          "color": "default",
          "href": null
        },
        {
          "type": "text",
          "text": "helped up-skill prototyping with ProtoPie",
          "bold": true,
          "italic": false,
          "strikethrough": false,
          "underline": false,
          "code": false,
          "color": "default",
          "href": null
        },
        {
          "type": "text",
          "text": ". This shift dramatically improved insight quality and final design decisions.",
          "bold": false,
