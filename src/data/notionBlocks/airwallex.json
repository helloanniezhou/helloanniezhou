      "type": "paragraph",
      "richText": [
        {
          "type": "text",
          "text": "Based on the research, I redefined use cases and edge cases and worked with design to iterate the UX with direct customer feedback.",
          "bold": false,
          "italic": false,
          "strikethrough": false,
          "underline": false,
