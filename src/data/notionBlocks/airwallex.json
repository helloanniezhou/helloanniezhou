    {
      "id": "340bef17-e035-80d4-8f2e-ced1d97840a5",
      "type": "paragraph",
      "richText": [
        {
          "type": "text",
          "text": "Airwallex is a fintech unicorn startup in the APAC region. As the Product Manager, I led the end-to-end development of Payment Link, a no-code tool that enables merchants to collect payments by sharing a URL. From problem discovery to launch, I drove alignment across design, engineering, operations, and go-to-market teams to ship a product serving businesses across markets and use cases.",
          "bold": false,
          "italic": false,
          "strikethrough": false,
          "underline": false,
          "code": false,
          "color": "default",
          "href": null
        }
      ]
    },
    {
      "id": "340bef17-e035-8028-bb79-e92b86772251",
      "type": "heading_3",
      "richText": [
        {
          "type": "text",
