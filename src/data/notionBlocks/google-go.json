    {
      "id": "340bef17-e035-800e-ac90-fb278b395c6c",
      "type": "paragraph",
      "richText": [
        {
          "type": "text",
          "text": "Google Go is a lightweight search app built for first-time smartphone users in regions like India and Sub-Saharan Africa. I led the design of key features that made Google Search more accessible for users with low literacy and digital fluency.",
          "bold": false,
          "italic": false,
          "strikethrough": false,
          "underline": false,
          "code": false,
          "color": "default",
          "href": null
        }
      ]
    },
    {
      "id": "340bef17-e035-809b-b82c-d90a0b2413f3",
      "type": "heading_3",
      "richText": [
        {
          "type": "text",
          "text": "Role",
          "bold": true,
          "italic": false,
          "strikethrough": false,
          "underline": false,
          "code": false,
          "color": "default",
          "href": null
        }
      ]
    },
    {
      "id": "340bef17-e035-80ff-b5ca-ee67b15509d6",
      "type": "paragraph",
      "richText": [
        {
          "type": "text",
          "text": "I was a UX designer responsible for onboarding and user education, in a group of 6 UXers, 2 PMs, and a team of engineers.",
          "bold": false,
          "italic": false,
          "strikethrough": false,
          "underline": false,
          "code": false,
          "color": "default",
          "href": null
        }
      ]
    },
    {
