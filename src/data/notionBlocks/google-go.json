    {
      "id": "340bef17-e035-8039-8304-daaeb0de9aa9",
      "type": "numbered_list_item",
      "richText": [
        {
          "type": "text",
          "text": "Ground the design in real user needs: ",
          "bold": true,
          "italic": false,
          "strikethrough": false,
          "underline": false,
          "code": false,
          "color": "default",
          "href": null
        },
        {
          "type": "text",
          "text": "Partnered with researchers on in-home visits across India and Nigeria. We observed how first-time smartphone users navigated digital content, revealing critical gaps in literacy, confidence, and comprehension.",
          "bold": false,
          "italic": false,
          "strikethrough": false,
          "underline": false,
          "code": false,
          "color": "default",
          "href": null
        }
      ],
      "children": []
    },
    {
      "id": "340bef17-e035-805c-9705-d8eb9f45501b",
      "type": "numbered_list_item",
      "richText": [
        {
          "type": "text",
          "text": "Prototype solutions: ",
          "bold": true,
          "italic": false,
          "strikethrough": false,
          "underline": false,
          "code": false,
          "color": "default",
          "href": null
        },
        {
          "type": "text",
          "text": "Collaborated with PMs and engineers to ideate and prototype audio-first interactions and simplified UI patterns. I created high-fidelity, interactive prototypes to test with low-literacy users in rapid research sessions.",
          "bold": false,
          "italic": false,
          "strikethrough": false,
          "underline": false,
          "code": false,
          "color": "default",
          "href": null
        }
      ],
      "children": []
    },
    {
