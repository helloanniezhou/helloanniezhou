      "type": "bulleted_list_item",
      "richText": [
        {
          "type": "text",
          "text": "Mini Learning videos drove a measurable lift, increasing feature usage by up to 1X%.",
          "bold": false,
          "italic": false,
          "strikethrough": false,
          "underline": false,
          "code": false,
          "color": "default",
          "href": null
        }
      ],
      "children": []
