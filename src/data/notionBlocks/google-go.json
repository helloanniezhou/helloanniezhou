          "href": null
        }
      ]
    },
    {
      "id": "340bef17-e035-80e3-8403-e7d0f63adfb1",
      "type": "bulleted_list_item",
      "richText": [
        {
          "type": "text",
          "text": "Karaoke mode reached X% of Google Go Search DAU with 1X% weekly retention, and earned a UK patent for its invention.",
          "bold": false,
          "italic": false,
          "strikethrough": false,
          "underline": false,
          "code": false,
          "color": "default",
          "href": null
        }
      ],
      "children": []
    },
    {
