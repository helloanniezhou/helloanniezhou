      "type": "numbered_list_item",
      "richText": [
        {
          "type": "text",
          "text": "Launch, learn, and scale: ",
          "bold": true,
          "italic": false,
          "strikethrough": false,
          "underline": false,
          "code": false,
          "color": "default",
          "href": null
        },
        {
          "type": "text",
          "text": "Post-launch, we monitored DAU, retention, and feature adoption weekly. These insights directly informed design iterations, content strategy, and future onboarding flows.",
          "bold": false,
          "italic": false,
          "strikethrough": false,
          "underline": false,
          "code": false,
          "color": "default",
          "href": null
        }
      ],
